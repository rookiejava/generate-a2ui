{
  "name": "generate-a2ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "a2ui-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/server/index.ts --format esm --dts --out-dir dist && vite build",
    "build:web": "vite build",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "smoke:provider": "tsx scripts/provider-smoke.ts",
    "smoke:deployment": "tsx scripts/deployment-smoke.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
